{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "avatar": { "type": "string" },
        "phone": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "PortfolioPhoto": {
      "title": "PortfolioPhoto",
      "description": "A photo in the portfolio",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string", "enum": ["Casamentos", "Eventos", "Ensaios", "Moda", "Corporativo"] },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url", "category", "title"]
    },
    "Package": {
      "title": "Package",
      "description": "A photography package",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "icon": { "type": "string" },
        "popular": { "type": "boolean" }
      },
      "required": ["title", "price", "features"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A photography session booking request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "type": { "type": "string" },
        "people": { "type": "number" },
        "location": { "type": "string" },
        "date": { "type": "string" },
        "duration": { "type": "number" },
        "coverage": { "type": "string" },
        "urgency": { "type": "string" },
        "budget": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "type", "people", "location", "date", "status", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A client review",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "content": { "type": "string" },
        "rating": { "type": "number" },
        "avatar": { "type": "string" }
      },
      "required": ["name", "content", "rating"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/portfolio": {
      "schema": "PortfolioPhoto",
      "description": "Portfolio photos"
    },
    "/packages": {
      "schema": "Package",
      "description": "Photography packages"
    },
    "/bookings": {
      "schema": "Booking",
      "description": "Session bookings"
    },
    "/reviews": {
      "schema": "Review",
      "description": "Client reviews"
    }
  }
}
