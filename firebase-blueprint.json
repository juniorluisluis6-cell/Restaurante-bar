{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "staff", "admin"] },
        "points": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "A food or drink item on the menu",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Chicken", "Burgers", "Pizzas", "Sides", "Drinks"] },
        "imageUrl": { "type": "string" },
        "prepTime": { "type": "number" },
        "available": { "type": "boolean" }
      },
      "required": ["name", "price", "category", "available"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "notes": { "type": "string" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["received", "preparing", "ready", "delivering", "delivered", "cancelled"] },
        "type": { "type": "string", "enum": ["delivery", "pickup"] },
        "address": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "paymentMethod": { "type": "string", "enum": ["cash", "mpesa"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "items", "total", "status", "type", "paymentMethod", "createdAt"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "A table reservation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "guests": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "date", "time", "guests", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/menu": {
      "schema": "MenuItem",
      "description": "Restaurant menu items"
    },
    "/orders": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/reservations": {
      "schema": "Reservation",
      "description": "Table reservations"
    }
  }
}
